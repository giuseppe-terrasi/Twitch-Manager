@using TwitchManager.Components.Abstractions
@using TwitchManager.Models

@inherits BaseComponent

<div class="row">
    <div class="col-12">
        <h1>
            @Selected.GameName
        </h1>
        <small class="user-badge-id"> votato da @Selected.ChatterUsername il @(Selected.VotedOn.ToString("dd/MM/yyyy HH:mm:ss"))</small>
    </div>
</div>
<div class="row mt-3">
    <div class="col-12 grid-2-items">
        <button class="btn btn-primary" @onclick="() => DialogService.Close()">
            @Localizer["CloseLabel"]
        </button>
    </div>
</div>
@code {
    [Parameter]
    public GameVoteModel Selected { get; set; }

    [Parameter]
    public DialogService DialogService { get; set; }
}
